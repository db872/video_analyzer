# Required: Google AI Studio / Gemini API key (server-only)
GEMINI_API_KEY=

# Required for persisted videos, analysis runs, memory, and reports
# Use a Neon Postgres connection string when running locally or on Vercel.
DATABASE_URL=

# Default video analysis model
GEMINI_MODEL=gemini-3.1-pro-preview

# Optional: use a different Gemini model for transcription
GEMINI_TRANSCRIPTION_MODEL=gemini-3-flash-preview

# Max upload size in bytes for multipart / temp path (default 2GB)
MAX_UPLOAD_BYTES=2147483648

# Screenshot sampling cadence for the video memory pipeline
SCREENSHOT_INTERVAL_SEC=8

# Hard cap on screenshots per analysis run to control cost/latency
MAX_SCREENSHOTS=16

# Chunk long extracted audio into smaller transcription requests (seconds)
TRANSCRIPTION_CHUNK_SEC=120

# Optional: Vercel Blob — set on Vercel for large uploads (client direct upload)
BLOB_READ_WRITE_TOKEN=

# Set to 1 on Vercel to show “Use Vercel Blob” and enable client upload flow
NEXT_PUBLIC_USE_BLOB_UPLOAD=
